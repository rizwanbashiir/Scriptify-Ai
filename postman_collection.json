{
  "info": {
    "_postman_id": "scriptify-ai-e2e-collection",
    "name": "Scriptify AI — End-to-End API Tests",
    "description": "Complete end-to-end Postman collection for Scriptify AI API. Run folders in order: Auth → Blogs → AI → Admin.\n\n**Setup:**\n1. Set collection variable `baseUrl` to `http://localhost:5000/api`\n2. Run the Auth folder first — it auto-extracts tokens and IDs\n3. Remaining folders use `{{accessToken}}`, `{{blogId}}`, etc. automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:5000/api", "type": "string" },
    { "key": "accessToken",  "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "userId",       "value": "", "type": "string" },
    { "key": "blogId",       "value": "", "type": "string" },
    { "key": "commentId",    "value": "", "type": "string" },
    { "key": "adminToken",   "value": "", "type": "string" },
    { "key": "testEmail",    "value": "e2etest_{{$randomInt}}@scriptify.dev", "type": "string" },
    { "key": "testPassword", "value": "TestPass123", "type": "string" }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "description": "Authentication flows: signup, verify, signin, token refresh, password reset, Google OAuth",
      "item": [

        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Status ok', () => { const b = pm.response.json(); pm.expect(b.status).to.eql('ok'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Sign Up",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"E2E\",\n  \"lastName\": \"Tester\",\n  \"email\": \"e2etest@scriptify.dev\",\n  \"password\": \"TestPass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/signup", "host": ["{{baseUrl}}"], "path": ["users", "signup"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201 — user created', () => pm.response.to.have.status(201));",
            "pm.test('Response has message', () => { const b = pm.response.json(); pm.expect(b).to.have.property('message'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Sign Up — Validation Error (missing password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Bad\",\n  \"lastName\": \"User\",\n  \"email\": \"bad@scriptify.dev\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/signup", "host": ["{{baseUrl}}"], "path": ["users", "signup"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — validation fails', () => pm.response.to.have.status(400));",
            "pm.test('Has errors array', () => { const b = pm.response.json(); pm.expect(b).to.have.property('errors'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Sign Up — Duplicate Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"E2E\",\n  \"lastName\": \"Tester\",\n  \"email\": \"e2etest@scriptify.dev\",\n  \"password\": \"TestPass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/signup", "host": ["{{baseUrl}}"], "path": ["users", "signup"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — duplicate email', () => pm.response.to.have.status(400));",
            "pm.test('Has message field', () => { const b = pm.response.json(); pm.expect(b).to.have.property('message'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"e2etest@scriptify.dev\" }"
            },
            "url": { "raw": "{{baseUrl}}/users/resend-otp", "host": ["{{baseUrl}}"], "path": ["users", "resend-otp"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('OTP resent message', () => { const b = pm.response.json(); pm.expect(b).to.have.property('message'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Verify Email (enter OTP from inbox)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2etest@scriptify.dev\",\n  \"otp\": \"ENTER_OTP_FROM_EMAIL\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/verify-email", "host": ["{{baseUrl}}"], "path": ["users", "verify-email"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 — email verified', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Verify Email — Wrong OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2etest@scriptify.dev\",\n  \"otp\": \"000000\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/verify-email", "host": ["{{baseUrl}}"], "path": ["users", "verify-email"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — invalid OTP', () => pm.response.to.have.status(400));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Sign In",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2etest@scriptify.dev\",\n  \"password\": \"TestPass123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/signin", "host": ["{{baseUrl}}"], "path": ["users", "signin"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has accessToken', () => { const b = pm.response.json(); pm.expect(b).to.have.property('accessToken'); pm.collectionVariables.set('accessToken', b.accessToken); });",
            "pm.test('Has refreshToken', () => { const b = pm.response.json(); pm.expect(b).to.have.property('refreshToken'); pm.collectionVariables.set('refreshToken', b.refreshToken); });",
            "pm.test('Has user object', () => { const b = pm.response.json(); pm.expect(b.user).to.have.property('_id'); pm.collectionVariables.set('userId', b.user._id); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Sign In — Wrong Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2etest@scriptify.dev\",\n  \"password\": \"WrongPassword999\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/signin", "host": ["{{baseUrl}}"], "path": ["users", "signin"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401 — invalid credentials', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"refreshToken\": \"{{refreshToken}}\" }"
            },
            "url": { "raw": "{{baseUrl}}/users/refresh-token", "host": ["{{baseUrl}}"], "path": ["users", "refresh-token"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('New accessToken issued', () => { const b = pm.response.json(); pm.expect(b).to.have.property('accessToken'); pm.collectionVariables.set('accessToken', b.accessToken); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Refresh Token — Invalid",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"refreshToken\": \"invalid.token.here\" }"
            },
            "url": { "raw": "{{baseUrl}}/users/refresh-token", "host": ["{{baseUrl}}"], "path": ["users", "refresh-token"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401 — invalid token', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"email\": \"e2etest@scriptify.dev\" }"
            },
            "url": { "raw": "{{baseUrl}}/users/forgot-password", "host": ["{{baseUrl}}"], "path": ["users", "forgot-password"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 — OTP sent', () => pm.response.to.have.status(200));",
            "pm.test('Has message', () => { const b = pm.response.json(); pm.expect(b).to.have.property('message'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Reset Password (enter OTP from inbox)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2etest@scriptify.dev\",\n  \"otp\": \"ENTER_OTP_FROM_EMAIL\",\n  \"newPassword\": \"NewPass456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/reset-password", "host": ["{{baseUrl}}"], "path": ["users", "reset-password"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200 — password reset', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}]
        }
      ]
    },

    {
      "name": "👤 Users",
      "description": "User profile, follow, bookmarks",
      "item": [

        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has _id', () => { const b = pm.response.json(); pm.expect(b).to.have.property('_id'); });",
            "pm.test('Has email', () => { const b = pm.response.json(); pm.expect(b).to.have.property('email'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Get User — Invalid ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/users/000000000000000000000000", "host": ["{{baseUrl}}"], "path": ["users", "000000000000000000000000"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 404 — not found', () => pm.response.to.have.status(404));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "firstName", "value": "Updated", "type": "text" },
                { "key": "lastName",  "value": "Tester",  "type": "text" },
                { "key": "bio",       "value": "E2E test bio — passionate about APIs!", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/users/profile", "host": ["{{baseUrl}}"], "path": ["users", "profile"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('firstName updated', () => { const b = pm.response.json(); pm.expect(b.firstName || b.user?.firstName).to.eql('Updated'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Update Profile — Unauthorized",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "firstName", "value": "Hacker", "type": "text" }]
            },
            "url": { "raw": "{{baseUrl}}/users/profile", "host": ["{{baseUrl}}"], "path": ["users", "profile"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 401', () => pm.response.to.have.status(401));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"TestPass123\",\n  \"newPassword\": \"TestPass456\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/change-password", "host": ["{{baseUrl}}"], "path": ["users", "change-password"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Change Password — Wrong Old Password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"oldPassword\": \"WrongOldPass\",\n  \"newPassword\": \"TestPass789\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/change-password", "host": ["{{baseUrl}}"], "path": ["users", "change-password"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400 — wrong old password', () => pm.response.to.have.status(400));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Get My Bookmarks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/users/me/bookmarks", "host": ["{{baseUrl}}"], "path": ["users", "me", "bookmarks"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Response is array', () => { const b = pm.response.json(); pm.expect(b).to.be.an('array'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"refreshToken\": \"{{refreshToken}}\" }"
            },
            "url": { "raw": "{{baseUrl}}/users/logout", "host": ["{{baseUrl}}"], "path": ["users", "logout"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Logged out message', () => { const b = pm.response.json(); pm.expect(b).to.have.property('message'); });"
          ], "type": "text/javascript" }}]
        }
      ]
    },

    {
      "name": "📝 Blogs",
      "description": "Blog CRUD, likes, comments",
      "item": [

        {
          "name": "Get All Blogs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/blogs?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["blogs"],
              "query": [
                { "key": "page",  "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has blogs array', () => { const b = pm.response.json(); pm.expect(b.blogs || b).to.be.an('array'); });",
            "pm.test('Has pagination', () => { const b = pm.response.json(); if (b.pagination) pm.expect(b.pagination).to.have.property('total'); });"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Get All Blogs — Search Filter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/blogs?search=AI&page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["blogs"],
              "query": [
                { "key": "search", "value": "AI" },
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "5" }
              ]
            }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ], "type": "text/javascript" }}]
        },

        {
          "name": "Create Blog",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title",   "value": "E2E Test Blog — AI Writing Tools", "type": "text" },
                { "key": "content", "value": "This is an automated end-to-end test blog post about AI writing tools. It contains enough content to pass validation requirements for the Scriptify platform.", "type": "text" },
                { "key": "tags",    "value": "[\"AI\",\"Testing\",\"Automation\"]", "type": "text" },
                { "key": "status",  "value": "published", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/blogs", "host": ["{{baseUrl}}"], "path": ["blogs"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Blog has _id', () => { const b = pm.response.json(); pm.expect(b._id || b.blog?._id).to.exist; pm.collectionVariables.set('blogId', b._id || b.blog?._id); });",
            "pm.test('Blog has title', () => { const b = pm.response.json(); pm.expect(b.title || b.blog?.title).to.exist; });"
          ], "type": "text/javascript" }}]
        },

