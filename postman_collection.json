        {
          "name": "Like Blog (Toggle)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/blogs/{{blogId}}/like", "host": ["{{baseUrl}}"], "path": ["blogs", "{{blogId}}", "like"] }
